{
    "manifest_version": 3,
    "name": "DeepReader",
    "version": "1.0",
    "description": "Get a domain expert to help you study and test papers.",
    "icons": {
        "16": "icons16.png",
        "48": "icons48.png",
        "128": "icons128.png"
    },
    "action": {
        "default_icon": "icons16.png",
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["*://*/*.pdf", "*://*/*.PDF"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "https://webhook.site/*"
    ],
    "permissions": ["activeTab"]
}
{
    "manifest_version": 3,
    "name": "GemReader",
    "version": "1.0",
    "description": "Get a personal Gemini powered PDF Assistant.",
    "icons": {
        "16": "icons16.png",
        "48": "icons48.png",
        "128": "icons128.png"
    },
    "action": {
        "default_icon": "icons48.png"
    },
    "content_scripts": [
        {
            "matches": ["*://*/*.pdf", "*://*/*.PDF"],
            "js": ["marked.min.js", "content.js"],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "http://localhost/*"
    ],
    "permissions": ["activeTab", "storage"],
    "web_accessible_resources": [
        {
            "resources": ["icons16.png", "icons48.png", "icons128.png"],
            "matches": ["<all_urls>"]
        }
    ]
}